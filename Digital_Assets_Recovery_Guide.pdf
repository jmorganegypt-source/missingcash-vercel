<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>

// ══ SPA ROUTER ══
function navigate(page) {
  // Remove active from all
  document.querySelectorAll('.spa-page').forEach(p => p.classList.remove('active'));
  const el = document.getElementById('page-' + page);
  if(el) { el.classList.add('active'); }
  window.scrollTo(0, 0);
  // Update URL hash without triggering hashchange
  history.pushState(null, '', page === 'home' ? '/' : '#' + page);
}

function routeFromHash() {
  const hash = location.hash.replace('#', '') || 'home';
  navigate(hash);
}

window.addEventListener('popstate', routeFromHash);

// Handle all hash links
document.addEventListener('click', function(e) {
  const a = e.target.closest('a[href^="#"]');
  if(a && !a.hasAttribute('onclick')) {
    const hash = a.getAttribute('href').replace('#', '');
    if(document.getElementById('page-' + hash)) {
      e.preventDefault();
      navigate(hash);
    }
  }
});

// Route on load
(function() {
  const hash = location.hash.replace('#', '') || 'home';
  if(hash !== 'home') {
    document.querySelectorAll('.spa-page').forEach(p => p.classList.remove('active'));
    const el = document.getElementById('page-' + hash);
    if(el) el.classList.add('active');
  }
})();

// Story modal data
function showStory(e, name) {
  e.preventDefault();
  const stories = {
    david: `<div style="text-align:center;margin-bottom:20px;"><div style="font-size:48px;">👴</div><h2 style="font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#fff;">David T. — Melbourne, VIC</h2><div style="font-size:1.4rem;color:var(--gold);font-family:'Bebas Neue',sans-serif;margin:8px 0;">$104,750 Found</div><div style="font-size:12px;color:var(--muted);">Lost Super · myGov / ATO · ★★★★★</div></div><p style="font-size:14px;color:var(--muted);line-height:1.7;">"I thought it was a mistake at first. That money had been quietly growing while I forgot about those old funds." David, 72, worked at four different employers over his career and lost track of super accounts when he changed jobs in the late 1980s and 1990s. Using the MissingCash guide, he logged into myGov, linked the ATO, and discovered three forgotten super accounts totalling $104,750 — with interest accumulated over decades. The claim process took two weeks.</p><p style="font-size:12px;color:var(--muted);margin-top:16px;font-style:italic;">Inspired by verified ATO & ASIC reunions. Individual results vary. Not a guarantee of any specific outcome.</p>`,
    sarah: `<div style="text-align:center;margin-bottom:20px;"><div style="font-size:48px;">👩</div><h2 style="font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#fff;">Sarah M. — Brisbane, QLD</h2><div style="font-size:1.4rem;color:var(--gold);font-family:'Bebas Neue',sans-serif;margin:8px 0;">$23,400 Found</div><div style="font-size:12px;color:var(--muted);">ASIC Unclaimed Money · Bank Account · ★★★★★</div></div><p style="font-size:14px;color:var(--muted);line-height:1.7;">"I searched my maiden name and found an old savings account from before I got married. I completely forgot it existed." Sarah, 41, found a dormant bank account registered under her maiden name through the ASIC MoneySmart search. The account had been transferred to ASIC after 7 years of inactivity. With interest accumulated under ASIC's holding, she claimed $23,400.</p><p style="font-size:12px;color:var(--muted);margin-top:16px;font-style:italic;">Inspired by verified ATO & ASIC reunions. Individual results vary. Not a guarantee of any specific outcome.</p>`,
    lisa: `<div style="text-align:center;margin-bottom:20px;"><div style="font-size:48px;">👩‍💼</div><h2 style="font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#fff;">Lisa K. — Sydney, NSW</h2><div style="font-size:1.4rem;color:var(--gold);font-family:'Bebas Neue',sans-serif;margin:8px 0;">$8,750 Found</div><div style="font-size:12px;color:var(--muted);">Rental Bond · NSW Fair Trading · ★★★★★</div></div><p style="font-size:14px;color:var(--muted);line-height:1.7;">"The bond from my first flat was still sitting there 12 years later. I had no idea you could still claim it." Lisa, 35, found an unclaimed rental bond from a flat she rented in her early 20s in Newtown. The bond had been held by NSW Fair Trading as an unclaimed bond and had grown with interest. She lodged a claim online with her old rental agreement and ID.</p><p style="font-size:12px;color:var(--muted);margin-top:16px;font-style:italic;">Inspired by verified ATO & ASIC reunions. Individual results vary. Not a guarantee of any specific outcome.</p>`
  };
  const modal = document.getElementById('story-modal');
  document.getElementById('story-content').innerHTML = stories[name] || '';
  modal.classList.add('open');
}

</script>
