<div class="spa-page" id="page-thank-you">
<style>
.ty-nav{position:sticky;top:0;z-index:100;background:rgba(6,24,38,0.97);border-bottom:1px solid rgba(245,185,66,0.15);padding:0 20px;display:flex;align-items:center;justify-content:space-between;height:56px;}
