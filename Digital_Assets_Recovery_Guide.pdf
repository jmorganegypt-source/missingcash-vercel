<!-- TRUST BAR -->
<div class="trust-bar">
  <span>🛡️ Official Government Sources</span>
  <span>·</span>
  <span>🔒 We Don't Store Your Data</span>
  <span>·</span>
  <span>🇦🇺 100% Free to Search</span>
  <span>·</span>
  <span>✅ ATO · ASIC · myGov</span>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-badge">🇦🇺 Trusted · Secure · 100% Free to Search</div>
  <h1 class="hero-title">
    <span class="line1">Find Your</span>
    <span class="line2">Missing Cash</span>
  </h1>
  <p class="hero-sub">Australians have <strong>billions sitting unclaimed</strong> with the government. Banks, the ATO & ASIC are holding your money — waiting for you to claim it.</p>

  <div class="live-ticker">
    <div class="ticker-dot"></div>
    <div class="ticker-label">Total Unclaimed in Australia</div>
    <div class="ticker-amount">$2,600,000,000+</div>
  </div>

  <div class="search-wrap">
    <div class="search-card">
      <h3>🔍 Search Your Name Now</h3>
      <div class="search-row">
        <input class="search-input" id="s-first" placeholder="First name" type="text" autocomplete="given-name">
        <input class="search-input" id="s-last" placeholder="Last name" type="text" autocomplete="family-name">
      </div>
      <div class="search-row">
        <select class="search-select" id="s-state">
          <option value="">All States</option>
          <option>NSW</option><option>VIC</option><option>QLD</option>
          <option>WA</option><option>SA</option><option>TAS</option><option>ACT</option><option>NT</option>
        </select>
        <input class="search-input" id="s-dob" placeholder="Birth year (optional)" type="number" min="1920" max="2005">
      </div>
      <button class="search-btn" id="search-btn" onclick="startSearch()">🔍 Search All Databases Now</button>
      <div class="search-note">🔒 Secure · ATO, ASIC, myGov, State Registers & more</div>
      <div id="scan-area">
        <div class="scan-label" id="scan-label">Scanning official databases...</div>
        <div class="scan-bars" id="scan-bars"></div>
      </div>
      <div id="results-area"></div>
    </div>
  </div>
</section>

<!-- STATS -->
<div class="stats-strip">
  <div class="stats-grid">
    <div class="stat-item reveal"><span class="stat-emoji">💰</span><span class="stat-num">$2.6B+</span><div class="stat-lbl">Unclaimed in Australia</div></div>
    <div class="stat-item reveal"><span class="stat-emoji">👤</span><span class="stat-num">1 in 5</span><div class="stat-lbl">Aussies have lost super</div></div>
    <div class="stat-item reveal"><span class="stat-emoji">💵</span><span class="stat-num">$13K+</span><div class="stat-lbl">Average lost per person</div></div>
    <div class="stat-item reveal"><span class="stat-emoji">⚡</span><span class="stat-num">2 min</span><div class="stat-lbl">To search all registers</div></div>
  </div>
</div>

<!-- WHAT WE SEARCH -->
<section class="section">
  <div class="section-label reveal">📋 What We Search</div>
  <h2 class="section-title reveal">We Scan Every Official Register</h2>
  <p class="section-sub reveal">One search covers all major Australian unclaimed money databases.</p>
  <div class="registers-grid">
    <div class="reg-card reveal"><span class="reg-icon">🏦</span><div class="reg-title">Unclaimed Money</div><div class="reg-sub">Bank accounts, shares & dividends inactive for 7+ years.</div><span class="reg-amount">$1 Billion+</span></div>
    <div class="reg-card reveal"><span class="reg-icon">🐷</span><div class="reg-title">Lost Superannuation</div><div class="reg-sub">Super becomes "lost" when funds can't locate you.</div><span class="reg-amount">$16 Billion+</span></div>
    <div class="reg-card reveal"><span class="reg-icon">🗺️</span><div class="reg-title">State Revenue Offices</div><div class="reg-sub">Each state holds unclaimed money. Often missed.</div><span class="reg-amount">$500M+</span></div>
    <div class="reg-card reveal"><span class="reg-icon">🏠</span><div class="reg-title">Rental Bond Refunds</div><div class="reg-sub">Thousands of rental bonds go unclaimed every year.</div><span class="reg-amount">100% Free</span></div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section style="padding:0 20px 80px;max-width:800px;margin:0 auto;">
  <div class="section-label reveal">⚡ How It Works</div>
  <h2 class="section-title reveal">Simple. Fast. Free.</h2>
  <div class="how-steps">
    <div class="how-step reveal"><div class="how-num">1</div><div class="how-content"><h3>Enter Your Name</h3><p>Type your name into the search box. Add state and birth year to narrow results.</p><div class="how-tag">✓ Takes 30 seconds</div></div></div>
    <div class="how-step reveal"><div class="how-num">2</div><div class="how-content"><h3>We Scan All Databases</h3><p>Our system checks ATO, ASIC, myGov, all state revenue offices and super funds simultaneously.</p><div class="how-tag">✓ 100% free to search</div></div></div>
    <div class="how-step reveal"><div class="how-num">3</div><div class="how-content"><h3>Unlock Your Results</h3><p>Unlock the full step-by-step claim guide for just $4.99. Complete the claim yourself — no lawyers, no agents.</p><div class="how-tag">✓ One-time $4.99 · Lifetime access</div></div></div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section style="padding:0 20px 80px;max-width:800px;margin:0 auto;">
  <div class="section-label reveal" style="justify-content:center;margin-bottom:10px;">⭐ Real Australian Results</div>
  <h2 class="section-title reveal" style="text-align:center;margin-bottom:6px;">What Australians Found</h2>
  <p class="section-sub reveal" style="text-align:center;margin-bottom:28px;">Inspired by verified ATO & ASIC reunions. Individual results vary.</p>
  <div class="testimonials-grid">
    <a href="#story-david" onclick="showStory(event,'david')" class="testi-card reveal">
      <div class="testi-top">
        <img src="data:image/jpeg;base64," alt="David T." class="testi-avatar">
        <div><div class="testi-name">David T.</div><div class="testi-meta">72 years old · Melbourne, VIC</div></div>
        <div><div class="testi-amount">$104,750</div><div class="testi-amount-label">Total Found</div></div>
      </div>
      <div class="testi-stars">★★★★★</div>
      <div class="testi-quote"><span class="q">"I thought it was a mistake at first. That money had been quietly growing while I forgot about those old funds."</span></div>
      <div class="testi-source">Lost Super · myGov / ATO</div>
      <div class="testi-readmore">Read Full Story →</div>
    </a>
    <a href="#" onclick="showStory(event,'sarah')" class="testi-card featured reveal">
      <div class="testi-top">
        <img src="data:image/jpeg;base64," alt="Sarah M." class="testi-avatar">
        <div><div class="testi-name">Sarah M.</div><div class="testi-meta">Regional Queensland</div></div>
        <div><div class="testi-amount">$500K+</div><div class="testi-amount-label">Total Found</div></div>
      </div>
