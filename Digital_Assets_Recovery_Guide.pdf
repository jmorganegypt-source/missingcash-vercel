    <img id="ava-hdr-face" src="data:image/png;base64," alt="Ava" style="width:44px;height:44px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(245,185,66,0.5);" onerror="this.src='https://i.pravatar.cc/150?img=47'">
