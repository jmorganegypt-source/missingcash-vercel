<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
// ══ SCROLL REVEAL ══
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('in'); });
}, {threshold:0.1});
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ══ STICKY CTA ══
window.addEventListener('scroll', () => {
  document.getElementById('sticky-cta').classList.toggle('show', window.scrollY > 600);
});

// ══ EXIT INTENT ══
let exitShown = false;
document.addEventListener('mouseleave', (e) => {
  if(e.clientY < 10 && !exitShown) { exitShown = true; setTimeout(() => document.getElementById('exit-popup').classList.add('show'), 200); }
});

// ══ FAQ ══
function toggleFaq(el) { el.parentElement.classList.toggle('open'); }

// ══ DATABASE SCAN ══
const DATABASES = [
  {name:'ATO — Superannuation', icon:'🐷'},
  {name:'ASIC — Unclaimed Money', icon:'🏦'},
  {name:'myGov — Lost Super', icon:'🏛️'},
  {name:'NSW Revenue Office', icon:'🗺️'},
  {name:'VIC State Revenue', icon:'🗺️'},
  {name:'QLD Revenue Office', icon:'🗺️'},
  {name:'AFCA — Financial Claims', icon:'⚖️'},
  {name:'Rental Bond Registers', icon:'🏠'},
];

function startSearch() {
  const first = document.getElementById('s-first').value.trim();
  const last = document.getElementById('s-last').value.trim();
  if(!first || !last) {
    ['s-first','s-last'].forEach(id => {
      document.getElementById(id).style.borderColor='rgba(248,113,113,0.6)';
      setTimeout(()=>document.getElementById(id).style.borderColor='',2000);
    });
    return;
  }
  const btn = document.getElementById('search-btn');
  btn.textContent = '🔍 Scanning...';
  btn.disabled = true;
  const scanArea = document.getElementById('scan-area');
  const scanBars = document.getElementById('scan-bars');
  scanArea.style.display = 'block';
  scanBars.innerHTML = '';
  DATABASES.forEach((db, i) => {
    const bar = document.createElement('div');
    bar.className = 'scan-bar';
    bar.innerHTML = `<span class="scan-bar-icon">${db.icon}</span><span class="scan-bar-name">${db.name}</span><div class="scan-bar-track"><div class="scan-bar-fill" id="sfill-${i}"></div></div><span class="scan-bar-status scanning" id="sstatus-${i}">Scanning...</span>`;
    scanBars.appendChild(bar);
  });
  DATABASES.forEach((db, i) => {
    setTimeout(() => {
      document.getElementById(`sfill-${i}`).style.width = '100%';
      setTimeout(() => {
        const s = document.getElementById(`sstatus-${i}`);
        s.textContent = '✓ Done'; s.className = 'scan-bar-status done';
        if(i === DATABASES.length - 1) setTimeout(() => showResults(first, last), 600);
      }, 1400);
    }, i * 320);
  });
}

function showResults(first, last) {
  document.getElementById('search-btn').textContent = '✓ Search Complete';
  document.getElementById('scan-label').textContent = '✅ Scan complete — records found!';
  const ra = document.getElementById('results-area');
  ra.style.display = 'block';
  ra.innerHTML = `
    <div class="result-header"><span style="font-size:20px;">⚠️</span><span class="result-header-text">Possible matches found for <strong>${first} ${last}</strong></span><span class="result-header-count">3 Records</span></div>
    <div class="result-item blurred"><div class="result-content"><div class="result-content-row"><div><div class="result-type">Lost Superannuation · ATO</div><div class="result-source">Account from previous employer</div></div><div class="result-amount">$██,███</div></div><div style="margin-top:6px;"><span class="result-status">● Unclaimed · Pending</span></div></div><div class="result-lock">🔒 Unlock to view details</div></div>
    <div class="result-item blurred"><div class="result-content"><div class="result-content-row"><div><div class="result-type">Unclaimed Money · ASIC</div><div class="result-source">Dormant bank/investment account</div></div><div class="result-amount">$█,███</div></div><div style="margin-top:6px;"><span class="result-status">● Unclaimed · Pending</span></div></div><div class="result-lock">🔒 Unlock to view details</div></div>
    <div class="result-item blurred"><div class="result-content"><div class="result-content-row"><div><div class="result-type">State Revenue Register</div><div class="result-source">Unclaimed property / bonds</div></div><div class="result-amount">$███</div></div><div style="margin-top:6px;"><span class="result-status">● Unclaimed · Pending</span></div></div><div class="result-lock">🔒 Unlock to view details</div></div>
    <div class="unlock-box"><div class="unlock-title">🔓 Unlock Your Full Results</div><div class="unlock-sub">Get the complete step-by-step guide to verify and claim every record found.</div><a href="https://buy.stripe.com/6oUbJ0eCE4FDbAFaYo4c800" class="unlock-btn" target="_blank">👑 Unlock Full Report — $4.99</a><div class="unlock-trust">🔒 Secure via Stripe · Instant access · 30-day money-back guarantee</div></div>`;
  ra.scrollIntoView({behavior:'smooth',block:'nearest'});
  gtag('event','search_completed',{'event_category':'engagement'});
}

// ══ AVA ══
// ── AVA SMART RESPONSES ──
const AVA_RESPONSES = [
  { keys:['super','superannuation','super fund'], reply:"Lost super is the biggest one — over $16 billion is sitting unclaimed with the ATO right now! 😮 1 in 5 Aussies has lost super from old jobs. Our Premium Guide walks you through exactly how to find and claim it via myGov. Have you worked at multiple jobs over the years?", chips:['Yes, multiple jobs!','How do I claim it?','What else could I have?'] },
  { keys:['crypto','bitcoin','coinspot','binance','wallet','seed'], reply:"Great news — lost crypto isn't always gone forever! 🔐 Our MissingCash Crypto Recovery Guide covers CoinSpot, Binance, Swyftx, Coinbase, hardware wallets and more — step by step. Even if you lost your password or 2FA. Which exchange or wallet are you dealing with?", chips:['CoinSpot','Binance / Swyftx','Hardware wallet','Lost password'] },
  { keys:['cost','price','how much','$4.99','4.99','pay','worth'], reply:"The Premium Guide is just $4.99 — a one-time lifetime payment. 💰 Most people who complete all the steps find at least one unclaimed amount, and the average Australian has $13,000+ sitting lost. It basically pays for itself many times over! Want to unlock it now?", chips:['Yes, unlock it! 🔓','What do I get?','Tell me more'] },
  { keys:['what do i get','included','inside','guide content'], reply:"The $4.99 guide covers everything — ASIC national search, lost super via myGov, all 8 state revenue registers, rental bond refunds, ATO tax credits, unpaid wages, and deceased estate claims. 📋 Plus a printable claim tracker and the 10 mistakes to avoid. It\'s a complete step-by-step playbook!", chips:['Unlock for $4.99 🔓','I have lost crypto too','How long does it take?'] },
  { keys:['how long','how does it work','how','work'], reply:"Super simple! Enter your name, we scan all the databases, and you see which records come up. 🔍 The full guide then shows you exactly how to verify and claim each one — directly with the government, no middleman. Most searches take under 2 minutes!", chips:['Search my name now','What could I find?','Unlock the guide 🔓'] },
  { keys:['free','cost nothing','no charge'], reply:"Searching is 100% free — always! 🇦🇺 We never charge to search. The $4.99 is for the step-by-step Premium Guide that shows you exactly how to claim what you find. The government holds the money for you indefinitely, so there\'s no rush — but why wait?", chips:['Search free now','Get the guide $4.99','What will I find?'] },
  { keys:['bond','rental','lease'], reply:"Rental bonds are one of the most overlooked ones! 🏠 Thousands of Australians forget to claim their bond after moving — especially interstate. Our guide has every state bond authority listed with phone numbers. Which state did you rent in?", chips:['NSW','VIC','QLD','Other state'] },
  { keys:['asic','ato','mygov','government'], reply:"ASIC holds over $2.6 billion in unclaimed bank accounts, shares and life insurance. The ATO holds $16B+ in lost super. 🏛️ Both are free to search — our guide walks you through both step by step, plus the state registers most people miss. Ready to start?", chips:['Search my name','Get the full guide','What else is there?'] },
  { keys:['scam','safe','legit','trust','real'], reply:"100% legitimate — we only link to official Australian government databases. 🛡️ We\'re not affiliated with any government agency, and we never ask for your personal details beyond your name. ABN 52 347 989 391. All searches go directly to ATO, ASIC and state revenue offices!", chips:['Search now — free','Tell me more','Get the guide'] },
  { keys:['deceased','estate','dead','passed away','family member'], reply:"You can absolutely claim on behalf of a family member who\'s passed away. 💙 As an executor, administrator or next of kin, you may be entitled to their unclaimed money. Our guide has a full chapter on deceased estate claims including what documents you\'ll need.", chips:['What documents?','Get the guide $4.99','Search their name'] },
  { keys:['wages','unpaid','fair work','employer'], reply:"Unpaid wages are more common than most people realise! ⚖️ The Fair Work Ombudsman holds unpaid wages, leave entitlements and redundancy payments. You can claim up to 6 years back — so don\'t delay. Our guide covers the exact steps to lodge a claim.", chips:['How do I claim?','Get the full guide','What else can I find?'] },
];
const AVA_DEFAULT = [
  "Great question! The most common finds are lost super, old bank accounts and unclaimed bonds. 💰 Have you ever worked multiple jobs or moved house a few times? There\'s a good chance something\'s waiting for you. Want me to walk you through what to search for?",
  "I\'m here to help you find every dollar that\'s owed to you! 🇦🇺 Australians have $2.6 billion in unclaimed cash plus $16 billion in lost super sitting with the government right now. Our $4.99 guide shows you how to claim it all yourself. What would you like to know?",
  "That\'s a great place to start! Most Australians are surprised by what they find — old super accounts, forgotten bank accounts, even uncashed dividends. 😊 The search is completely free, and our step-by-step guide for $4.99 shows you exactly how to claim. Shall we start searching?",
];
let avaDefaultIdx = 0, avaStarted = false, avaBusy = false;
const CHIPS = ['Yes, check my super! 🙌','What money could I find?','I have lost crypto 🔐','How does it work?'];

function avaSpeak(text) {
  if (!window.speechSynthesis) return;
  window.speechSynthesis.cancel();
  const msg = new SpeechSynthesisUtterance(text);
  const setVoice = () => {
    const voices = window.speechSynthesis.getVoices();
    const v = voices.find(v => v.lang === 'en-AU') || voices.find(v => v.name.toLowerCase().includes('female')) || voices[0];
    if(v) msg.voice = v;
    msg.pitch = 1.15; msg.rate = 0.95;
    window.speechSynthesis.speak(msg);
  };
  window.speechSynthesis.getVoices().length === 0 ? (window.speechSynthesis.onvoiceschanged = setVoice) : setVoice();
}

function avaOpen() {
  document.getElementById('ava-promo').style.display = 'none';
  document.getElementById('ava-badge').style.display = 'none';
  document.getElementById('ava-win').classList.add('open');
  if(!avaStarted) {
    avaStarted = true;
    setTimeout(() => avaType("Hi there! 👋 I'm Ava, and my dad created me to guide Australians like you through finding lost money — step by step, no stress, no confusion! Have you ever checked for lost super or unclaimed money?", true), 500);
  }
  setTimeout(() => document.getElementById('ava-input').focus(), 400);
}

function avaClose() {
  document.getElementById('ava-win').classList.remove('open');
  if(window.speechSynthesis) window.speechSynthesis.cancel();
}

function avaKey(e) { if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();avaSend();} }

function avaType(text, showChips) {
  const msgs = document.getElementById('ava-msgs');
  const typing = document.createElement('div');
  typing.className = 'ava-msg typing'; typing.id = 'ava-typing';
  typing.innerHTML = '<div class="ava-dots"><span></span><span></span><span></span></div>';
  msgs.appendChild(typing); msgs.scrollTop = msgs.scrollHeight;
  setTimeout(() => {
    document.getElementById('ava-typing')?.remove();
    const div = document.createElement('div'); div.className = 'ava-msg bot';
    msgs.appendChild(div);
    let i = 0;
    const iv = setInterval(() => {
      div.textContent = text.slice(0,i++); msgs.scrollTop = msgs.scrollHeight;
      if(i > text.length) { clearInterval(iv); avaSpeak(text); if(showChips) avaChips(CHIPS); }
    }, 16);
  }, Math.min(500 + text.length*16, 2000));
}

function avaChips(chips) {
  const msgs = document.getElementById('ava-msgs');
  const row = document.createElement('div'); row.className = 'ava-chips'; row.id = 'ava-chips-row';
  chips.forEach(label => {
    const btn = document.createElement('button'); btn.className = 'ava-chip'; btn.textContent = label;
    btn.onclick = () => { document.getElementById('ava-chips-row')?.remove(); avaUserSay(label); };
    row.appendChild(btn);
  });
  msgs.appendChild(row); msgs.scrollTop = msgs.scrollHeight;
}

function avaUserSay(text) {
  if(avaBusy) return;
  document.getElementById('ava-chips-row')?.remove();
  const msgs = document.getElementById('ava-msgs');
  const div = document.createElement('div'); div.className = 'ava-msg user'; div.textContent = text;
  msgs.appendChild(div); msgs.scrollTop = msgs.scrollHeight;
  avaSmartReply(text);
}

async function avaSend() {
  const input = document.getElementById('ava-input');
  const text = input.value.trim();
  if(!text||avaBusy) return; input.value=''; avaUserSay(text);
}

function avaSmartReply(userText) {
  avaBusy = true; document.getElementById('ava-send').disabled = true;
  const msgs = document.getElementById('ava-msgs');
  const typing = document.createElement('div'); typing.className='ava-msg typing'; typing.id='ava-typing2';
  typing.innerHTML='<div class="ava-dots"><span></span><span></span><span></span></div>';
  msgs.appendChild(typing); msgs.scrollTop=msgs.scrollHeight;
  const lower = userText.toLowerCase();
  let match = null;
  for(const r of AVA_RESPONSES) {
    if(r.keys.some(k => lower.includes(k))) { match = r; break; }
  }
  const reply = match ? match.reply : AVA_DEFAULT[avaDefaultIdx++ % AVA_DEFAULT.length];
  const chips = match?.chips || CHIPS;
  setTimeout(() => {
    document.getElementById('ava-typing2')?.remove();
    const div = document.createElement('div'); div.className='ava-msg bot'; msgs.appendChild(div);
    let i=0; const iv=setInterval(()=>{
      div.textContent=reply.slice(0,i++); msgs.scrollTop=msgs.scrollHeight;
      if(i>reply.length){ clearInterval(iv); avaSpeak(reply); avaChips(chips); }
    },14);
    avaBusy=false; document.getElementById('ava-send').disabled=false;
    document.getElementById('ava-input').focus();
  }, 900);
}

setTimeout(() => { if(!avaStarted) document.getElementById('ava-promo').style.display='block'; }, 7000);
</script>


</div>

