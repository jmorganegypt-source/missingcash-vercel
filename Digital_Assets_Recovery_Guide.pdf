<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>MissingCash — Find Your Lost Money, Super & Shares | Australia</title>
<meta name="description" content="Search Australia's unclaimed money registers FREE. Find lost super, unclaimed bank accounts, forgotten shares and rental bonds. Over $2.6 billion waiting to be claimed.">
<link rel="canonical" href="https://missingcash.com.au/">
<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-1LLNFV2MEQ"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-1LLNFV2MEQ');</script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ═══ SPA ROUTER ═══ */
.spa-page{display:none;}
.spa-page.active{display:block;}
/* ═══ HOME PAGE STYLES ═══ */

:root{--gold:#f5b942;--gold-dark:#e8a020;--navy:#061826;--navy-mid:#0b2a3d;--navy-light:#1a3a52;--text:#dde8f5;--muted:#7a9ab5;--green:#00e676;}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--navy);color:var(--text);line-height:1.6;overflow-x:hidden;}

/* REVEAL */
.reveal{opacity:0;transform:translateY(30px);transition:opacity 0.6s ease,transform 0.6s ease;}
.reveal.in{opacity:1;transform:translateY(0);}

/* NAVBAR */
.navbar{position:sticky;top:0;z-index:100;background:rgba(6,24,38,0.97);backdrop-filter:blur(16px);border-bottom:1px solid rgba(245,185,66,0.12);padding:0 20px;display:flex;align-items:center;justify-content:space-between;height:64px;}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.nav-logo-icon{width:36px;height:36px;background:linear-gradient(135deg,var(--gold),var(--gold-dark));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;}
.nav-brand{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:var(--gold);letter-spacing:0.05em;}
.nav-sub{font-size:10px;color:var(--muted);}
.nav-links{display:flex;align-items:center;gap:8px;}
.nav-link{color:var(--muted);font-size:13px;font-weight:600;text-decoration:none;padding:6px 10px;border-radius:8px;}
.nav-link:hover{color:var(--text);}
.nav-cta{background:var(--gold);color:#000;font-size:13px;font-weight:700;padding:8px 16px;border-radius:20px;text-decoration:none;}

/* TRUST BAR */
.trust-bar{background:rgba(245,185,66,0.07);border-bottom:1px solid rgba(245,185,66,0.1);padding:9px 20px;display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;font-size:12px;font-weight:700;color:var(--gold);letter-spacing:0.04em;}

/* HERO */
.hero{position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 20px 40px;text-align:center;background:radial-gradient(ellipse at 30% 20%,#0f2a48 0%,#061826 65%);}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(245,185,66,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(245,185,66,0.03) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse at center,black 30%,transparent 80%);}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(0,230,118,0.1);border:1px solid rgba(0,230,118,0.3);border-radius:100px;padding:8px 20px;font-size:12px;font-weight:700;color:var(--green);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:24px;animation:badge-in 0.6s 0.2s both;}
@keyframes badge-in{from{opacity:0;transform:translateY(-16px);}to{opacity:1;transform:translateY(0);}}
.hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.2rem,14vw,5.5rem);line-height:0.95;letter-spacing:0.02em;margin-bottom:20px;animation:title-in 0.8s 0.3s both;}
@keyframes title-in{from{opacity:0;transform:translateY(30px);}to{opacity:1;transform:translateY(0);}}
.hero-title .line1{color:#fff;display:block;}
.hero-title .line2{color:var(--gold);display:block;}
.hero-sub{font-size:clamp(15px,4vw,17px);color:var(--muted);max-width:460px;margin:0 auto 30px;line-height:1.65;animation:title-in 0.7s 0.5s both;}
.hero-sub strong{color:var(--text);}

/* LIVE TICKER */
.live-ticker{display:inline-flex;align-items:center;gap:12px;background:rgba(11,42,61,0.8);border:1px solid rgba(245,185,66,0.2);border-radius:14px;padding:12px 20px;margin-bottom:30px;animation:title-in 0.6s 0.7s both;}
.ticker-dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:tick 1.5s ease-in-out infinite;}
@keyframes tick{0%,100%{box-shadow:0 0 0 0 rgba(0,230,118,0.5);}50%{box-shadow:0 0 0 8px rgba(0,230,118,0);}}
.ticker-label{font-size:12px;color:var(--muted);font-weight:600;}
.ticker-amount{font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--gold);}

/* SEARCH */
.search-wrap{width:100%;max-width:520px;animation:title-in 0.7s 0.8s both;}
.search-card{background:rgba(11,42,61,0.9);border:1px solid rgba(245,185,66,0.2);border-radius:24px;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.3);}
.search-card h3{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:0.04em;color:#fff;margin-bottom:16px;text-align:center;}
.search-row{display:flex;gap:10px;margin-bottom:10px;}
.search-input{flex:1;background:rgba(6,24,38,0.8);border:1px solid var(--navy-light);border-radius:12px;padding:13px 16px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:15px;outline:none;}
.search-input:focus{border-color:rgba(245,185,66,0.5);}
.search-input::placeholder{color:var(--muted);}
.search-select{background:rgba(6,24,38,0.8);border:1px solid var(--navy-light);border-radius:12px;padding:13px 14px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;outline:none;cursor:pointer;}
.search-btn{width:100%;background:linear-gradient(135deg,var(--gold),var(--gold-dark));border:none;border-radius:14px;padding:16px;font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:0.05em;color:#000;cursor:pointer;box-shadow:0 6px 24px rgba(245,185,66,0.3);transition:transform 0.15s;}
.search-btn:hover{transform:translateY(-2px);}
.search-note{font-size:11px;color:var(--muted);text-align:center;margin-top:10px;}
@media(max-width:500px){.search-row{flex-direction:column;}}

/* SCAN */
#scan-area{display:none;margin-top:16px;}
.scan-label{font-size:12px;color:var(--muted);text-align:center;margin-bottom:8px;font-weight:600;}
.scan-bars{display:flex;flex-direction:column;gap:6px;}
.scan-bar{background:rgba(6,24,38,0.8);border:1px solid var(--navy-light);border-radius:8px;padding:10px 14px;display:flex;align-items:center;gap:12px;font-size:13px;}
.scan-bar-icon{font-size:16px;flex-shrink:0;}
.scan-bar-name{flex:1;color:var(--text);font-weight:600;}
.scan-bar-track{flex:1;height:4px;background:rgba(245,185,66,0.1);border-radius:2px;overflow:hidden;}
.scan-bar-fill{height:100%;background:linear-gradient(90deg,var(--gold),var(--green));width:0%;transition:width 1.2s ease-out;border-radius:2px;}
.scan-bar-status{font-size:11px;font-weight:700;min-width:60px;text-align:right;}
.scan-bar-status.scanning{color:var(--gold);animation:blink 0.8s step-end infinite;}
.scan-bar-status.done{color:var(--green);}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}

/* RESULTS */
#results-area{display:none;margin-top:16px;}
.result-header{display:flex;align-items:center;gap:10px;background:rgba(0,230,118,0.08);border:1px solid rgba(0,230,118,0.25);border-radius:12px;padding:12px 16px;margin-bottom:12px;}
.result-header-text{font-size:13px;color:var(--text);font-weight:700;}
.result-header-count{font-family:'Bebas Neue',sans-serif;font-size:18px;color:var(--green);margin-left:auto;}
.result-item{position:relative;background:rgba(6,24,38,0.9);border:1px solid var(--navy-light);border-radius:12px;padding:14px 16px;margin-bottom:8px;overflow:hidden;}
.result-item.blurred .result-content{filter:blur(5px);user-select:none;}
.result-lock{position:absolute;inset:0;background:linear-gradient(135deg,rgba(6,24,38,0.85),rgba(11,42,61,0.9));display:flex;align-items:center;justify-content:center;gap:8px;font-size:13px;font-weight:700;color:var(--gold);border-radius:12px;}
.result-content-row{display:flex;align-items:center;justify-content:space-between;}
.result-type{font-size:11px;color:var(--muted);font-weight:600;letter-spacing:0.05em;text-transform:uppercase;}
.result-amount{font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--gold);}
.result-source{font-size:12px;color:var(--muted);margin-top:4px;}
.result-status{font-size:11px;color:var(--green);font-weight:700;background:rgba(0,230,118,0.1);border:1px solid rgba(0,230,118,0.2);border-radius:20px;padding:3px 10px;}
.unlock-box{background:linear-gradient(135deg,rgba(245,185,66,0.08),rgba(245,185,66,0.03));border:2px solid rgba(245,185,66,0.3);border-radius:16px;padding:20px;text-align:center;margin-top:12px;}
.unlock-title{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;color:#fff;margin-bottom:6px;}
.unlock-sub{font-size:13px;color:var(--muted);margin-bottom:16px;line-height:1.5;}
.unlock-btn{display:block;background:linear-gradient(135deg,var(--gold),var(--gold-dark));border-radius:50px;padding:16px 28px;font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#000;letter-spacing:0.05em;text-decoration:none;box-shadow:0 6px 24px rgba(245,185,66,0.35);animation:cta-glow 2.5s ease-in-out infinite;}
@keyframes cta-glow{0%,100%{box-shadow:0 6px 24px rgba(245,185,66,0.35);}50%{box-shadow:0 8px 40px rgba(245,185,66,0.6);}}
.unlock-trust{font-size:11px;color:var(--muted);margin-top:10px;}

/* STATS */
.stats-strip{background:rgba(11,42,61,0.6);border-top:1px solid rgba(245,185,66,0.08);border-bottom:1px solid rgba(245,185,66,0.08);padding:40px 20px;}
.stats-grid{max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:24px;text-align:center;}
.stat-num{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,6vw,3rem);color:var(--gold);line-height:1;display:block;}
.stat-emoji{font-size:28px;display:block;margin-bottom:6px;}
.stat-lbl{font-size:13px;color:var(--muted);margin-top:6px;}

/* SECTION */
.section{padding:80px 20px;max-width:800px;margin:0 auto;}
.section-label{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);margin-bottom:12px;}
.section-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,7vw,3rem);color:#fff;letter-spacing:0.02em;margin-bottom:8px;line-height:1.05;}
.section-sub{font-size:15px;color:var(--muted);line-height:1.7;margin-bottom:40px;}

/* REGISTERS */
.registers-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin-bottom:40px;}
.reg-card{background:rgba(11,42,61,0.7);border:1px solid var(--navy-light);border-radius:18px;padding:20px;transition:border-color 0.2s,transform 0.2s;}
.reg-card:hover{border-color:rgba(245,185,66,0.3);transform:translateY(-3px);}
.reg-icon{font-size:28px;margin-bottom:10px;display:block;}
.reg-title{font-size:15px;font-weight:700;color:#fff;margin-bottom:4px;}
.reg-sub{font-size:12px;color:var(--muted);line-height:1.5;}
.reg-amount{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:var(--gold);margin-top:10px;display:block;}

/* HOW */
.how-steps{display:flex;flex-direction:column;}
.how-step{display:flex;gap:20px;padding:24px 0;border-bottom:1px solid rgba(245,185,66,0.06);}
.how-step:last-child{border-bottom:none;}
.how-num{width:48px;height:48px;border-radius:50%;background:rgba(245,185,66,0.1);border:2px solid rgba(245,185,66,0.3);color:var(--gold);font-family:'Bebas Neue',sans-serif;font-size:1.3rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.how-content h3{font-size:17px;font-weight:700;color:#fff;margin-bottom:4px;}
.how-content p{font-size:14px;color:var(--muted);line-height:1.6;}
.how-tag{display:inline-flex;align-items:center;font-size:10px;font-weight:700;background:rgba(0,230,118,0.1);border:1px solid rgba(0,230,118,0.2);border-radius:20px;padding:3px 10px;color:var(--green);margin-top:8px;}

/* TESTIMONIALS */
.testimonials-grid{display:flex;flex-direction:column;gap:14px;}
.testi-card{background:rgba(11,42,61,0.8);border:1px solid var(--navy-light);border-radius:20px;padding:20px;text-decoration:none;color:inherit;display:block;transition:border-color 0.2s,transform 0.2s;}
.testi-card:hover{border-color:rgba(245,185,66,0.4);transform:translateY(-3px);}
.testi-card.featured{border-color:rgba(245,185,66,0.3);background:rgba(245,185,66,0.04);}
.testi-top{display:flex;align-items:center;gap:14px;margin-bottom:14px;}
.testi-avatar{width:56px;height:56px;border-radius:50%;object-fit:cover;border:2px solid var(--gold);flex-shrink:0;}
.testi-name{font-weight:700;font-size:16px;color:#fff;}
.testi-meta{font-size:12px;color:var(--muted);margin-top:2px;}
.testi-amount{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;color:var(--gold);margin-left:auto;text-align:right;line-height:1;}
.testi-amount-label{font-size:11px;color:var(--muted);text-align:right;}
.testi-stars{color:var(--gold);font-size:14px;letter-spacing:2px;margin-bottom:8px;}
.testi-quote{font-size:14px;color:var(--muted);line-height:1.65;font-style:italic;}
.testi-quote .q{color:var(--text);}
.testi-source{font-size:11px;color:var(--muted);margin-top:10px;opacity:0.7;}
.testi-readmore{display:inline-flex;align-items:center;font-size:12px;font-weight:700;color:var(--gold);margin-top:12px;}

/* PREMIUM */
.premium-section{padding:80px 20px;background:linear-gradient(180deg,var(--navy) 0%,rgba(11,42,61,0.5) 50%,var(--navy) 100%);}
.premium-card{max-width:600px;margin:0 auto;background:linear-gradient(135deg,rgba(11,42,61,0.9),rgba(6,24,38,0.9));border:1px solid rgba(245,185,66,0.25);border-radius:28px;padding:36px 28px;text-align:center;box-shadow:0 24px 80px rgba(0,0,0,0.4);}
.premium-crown{font-size:40px;margin-bottom:10px;display:block;animation:float 3s ease-in-out infinite;}
@keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-8px);}}
.premium-title{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#fff;letter-spacing:0.03em;margin-bottom:6px;}
.premium-sub{font-size:14px;color:var(--muted);margin-bottom:24px;line-height:1.6;}
.premium-features{text-align:left;margin-bottom:28px;display:flex;flex-direction:column;gap:10px;}
.feat-item{display:flex;align-items:flex-start;gap:12px;font-size:14px;color:var(--text);}
.feat-check{color:var(--green);font-weight:700;flex-shrink:0;font-size:16px;}
.premium-price{font-family:'Bebas Neue',sans-serif;font-size:3.5rem;color:var(--gold);line-height:1;margin-bottom:4px;}
.premium-price-note{font-size:13px;color:var(--muted);margin-bottom:20px;}
.premium-btn{display:block;background:linear-gradient(135deg,var(--gold),var(--gold-dark));border-radius:50px;padding:18px 32px;font-family:'Bebas Neue',sans-serif;font-size:1.4rem;color:#000;letter-spacing:0.05em;text-decoration:none;box-shadow:0 8px 32px rgba(245,185,66,0.35);animation:cta-glow 2s ease-in-out infinite;}
.premium-trust{font-size:12px;color:var(--muted);margin-top:14px;}

/* CRYPTO */
.crypto-section{padding:80px 20px;background:rgba(11,42,61,0.3);border-top:1px solid rgba(245,185,66,0.06);border-bottom:1px solid rgba(245,185,66,0.06);}
.crypto-inner{max-width:800px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;}
@media(max-width:600px){.crypto-inner{grid-template-columns:1fr;}}
.crypto-platforms{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.crypto-pill{background:rgba(6,24,38,0.8);border:1px solid var(--navy-light);border-radius:12px;padding:12px 14px;display:flex;align-items:center;gap:10px;font-size:13px;font-weight:600;color:var(--text);}

/* FAQ */
.faq-list{display:flex;flex-direction:column;gap:10px;max-width:700px;margin:0 auto;}
.faq-item{background:rgba(11,42,61,0.7);border:1px solid var(--navy-light);border-radius:14px;overflow:hidden;}
.faq-q{padding:16px 20px;font-weight:700;font-size:15px;color:#fff;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:12px;}
.faq-q:hover{color:var(--gold);}
.faq-arrow{color:var(--gold);font-size:18px;transition:transform 0.3s;flex-shrink:0;}
.faq-item.open .faq-arrow{transform:rotate(45deg);}
.faq-a{max-height:0;overflow:hidden;font-size:14px;color:var(--muted);line-height:1.7;transition:max-height 0.4s ease,padding 0.3s;padding:0 20px;}
.faq-item.open .faq-a{max-height:300px;padding:0 20px 16px;}

/* EXIT POPUP */
#exit-popup{display:none;position:fixed;inset:0;z-index:9998;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:20px;}
#exit-popup.show{display:flex;}
.exit-card{background:var(--navy-mid);border:1px solid rgba(245,185,66,0.3);border-radius:24px;padding:32px 28px;max-width:400px;width:100%;text-align:center;position:relative;animation:popup-in 0.4s cubic-bezier(0.34,1.56,0.64,1);}
@keyframes popup-in{from{opacity:0;transform:scale(0.85) translateY(20px);}to{opacity:1;transform:scale(1) translateY(0);}}
.exit-close{position:absolute;top:14px;right:16px;background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;}
.exit-title{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;color:#fff;margin-bottom:8px;}
.exit-title span{color:var(--gold);}
.exit-sub{font-size:14px;color:var(--muted);margin-bottom:20px;line-height:1.6;}
.exit-btn{display:block;background:linear-gradient(135deg,var(--gold),var(--gold-dark));border-radius:50px;padding:16px;font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#000;text-decoration:none;margin-bottom:10px;}
.exit-dismiss{font-size:12px;color:var(--muted);cursor:pointer;text-decoration:underline;}

/* FOOTER */
footer{background:rgba(0,0,0,0.3);border-top:1px solid var(--navy-light);padding:30px 20px;text-align:center;font-size:12px;color:var(--muted);}
footer a{color:var(--muted);text-decoration:none;}
footer a:hover{color:var(--gold);}
.footer-links{display:flex;justify-content:center;gap:20px;flex-wrap:wrap;margin-bottom:12px;}

/* STICKY CTA */
#sticky-cta{position:fixed;bottom:0;left:0;right:0;z-index:90;background:linear-gradient(to top,rgba(6,24,38,0.98),rgba(6,24,38,0.9));padding:12px 16px 16px;border-top:1px solid rgba(245,185,66,0.15);display:none;gap:10px;align-items:center;}
#sticky-cta.show{display:flex;}
.sticky-text{flex:1;font-size:12px;color:var(--muted);}
.sticky-text strong{display:block;color:var(--text);font-size:13px;}
.sticky-btn{background:linear-gradient(135deg,var(--gold),var(--gold-dark));border-radius:20px;padding:10px 18px;font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#000;text-decoration:none;white-space:nowrap;flex-shrink:0;}

/* AVA */
#ava-wrap{position:fixed;bottom:24px;right:24px;z-index:10000;display:flex;flex-direction:column;align-items:flex-end;gap:10px;}
#ava-promo{display:none;background:var(--navy-mid);border:1px solid rgba(245,185,66,0.4);border-radius:18px 18px 4px 18px;padding:12px 16px;max-width:220px;font-size:13px;color:#fff;line-height:1.5;box-shadow:0 4px 20px rgba(0,0,0,0.4);cursor:pointer;animation:ava-slide 0.4s ease;}
@keyframes ava-slide{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
#ava-promo strong{color:var(--gold);}
#ava-promo-close{float:right;color:var(--muted);margin-left:8px;font-size:16px;line-height:1;cursor:pointer;}
#ava-btn{width:72px;height:72px;border-radius:50%;cursor:pointer;position:relative;border:3px solid var(--gold);background:none;padding:2px;overflow:hidden;animation:ava-pulse 2.5s infinite;}
@keyframes ava-pulse{0%,100%{filter:drop-shadow(0 0 8px rgba(245,185,66,0.4));}50%{filter:drop-shadow(0 0 20px rgba(245,185,66,0.7));}}
#ava-badge{position:absolute;top:-4px;right:-4px;background:var(--gold);color:#000;font-size:10px;font-weight:900;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;border:2px solid var(--navy);animation:badge-pop 1s ease-in-out infinite;}
@keyframes badge-pop{0%,100%{transform:scale(1);}50%{transform:scale(1.2);}}
#ava-win{display:none;position:fixed;bottom:110px;right:24px;width:340px;max-width:calc(100vw - 40px);background:var(--navy);border:1px solid rgba(245,185,66,0.2);border-radius:22px;box-shadow:0 16px 60px rgba(0,0,0,0.6);z-index:10000;flex-direction:column;overflow:hidden;transform:scale(0.9) translateY(16px);opacity:0;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1),opacity 0.3s ease;}
#ava-win.open{display:flex;transform:scale(1) translateY(0);opacity:1;}
#ava-hdr{background:linear-gradient(135deg,#0b2a3d,#1a3a52);border-bottom:2px solid rgba(245,185,66,0.4);padding:14px 18px;display:flex;align-items:center;gap:12px;}
#ava-hdr-face{width:44px;height:44px;flex-shrink:0;}
#ava-hdr-info{flex:1;}
#ava-hdr-name{color:#fff;font-weight:800;font-size:14px;}
#ava-hdr-sub{color:rgba(255,255,255,0.8);font-size:11px;margin-top:2px;}
#ava-close{color:#fff;background:none;border:none;font-size:22px;cursor:pointer;padding:0;opacity:0.8;}
#ava-msgs{overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px;max-height:300px;min-height:160px;scroll-behavior:smooth;}
.ava-msg{max-width:88%;padding:10px 14px;border-radius:16px;font-size:13px;line-height:1.55;animation:msg-in 0.3s ease;}
@keyframes msg-in{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.ava-msg.bot{background:var(--navy-mid);color:var(--text);align-self:flex-start;border-bottom-left-radius:4px;border:1px solid var(--navy-light);}
.ava-msg.user{background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:#000;align-self:flex-end;border-bottom-right-radius:4px;font-weight:600;}
.ava-msg.typing{background:var(--navy-mid);border:1px solid var(--navy-light);align-self:flex-start;padding:12px 16px;}
.ava-dots{display:flex;gap:5px;align-items:center;}
.ava-dots span{width:7px;height:7px;border-radius:50%;background:var(--muted);display:inline-block;}
.ava-dots span:nth-child(1){animation:ava-dot 1.2s 0s infinite;}
.ava-dots span:nth-child(2){animation:ava-dot 1.2s 0.2s infinite;}
.ava-dots span:nth-child(3){animation:ava-dot 1.2s 0.4s infinite;}
@keyframes ava-dot{0%,60%,100%{transform:translateY(0);}30%{transform:translateY(-6px);}}
.ava-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:2px;align-self:flex-start;}
.ava-chip{background:rgba(245,185,66,0.1);border:1px solid rgba(245,185,66,0.35);border-radius:20px;padding:6px 12px;font-size:12px;color:var(--gold);cursor:pointer;font-weight:700;transition:background 0.15s;}
.ava-chip:hover{background:rgba(245,185,66,0.25);color:#fff;}
#ava-input-row{padding:10px 12px;border-top:1px solid var(--navy-light);display:flex;gap:8px;background:var(--navy);}
#ava-input{flex:1;background:var(--navy-mid);border:1px solid var(--navy-light);border-radius:12px;padding:10px 13px;color:var(--text);font-size:13px;outline:none;resize:none;min-height:40px;max-height:80px;}
#ava-input:focus{border-color:var(--gold);}
#ava-send{background:linear-gradient(135deg,var(--gold),var(--gold-dark));border:none;border-radius:12px;padding:10px 14px;color:#000;cursor:pointer;font-size:17px;font-weight:700;}
#ava-send:disabled{opacity:0.4;}

/* ═══ THANK-YOU PAGE STYLES ═══ */

:root{
  --navy:#061826; --card:#0b2a3d; --border:#1a3a52;
  --gold:#f5b942; --gold2:#ffd47a;
  --green:#00c853; --green2:#00e676;
  --teal:#00c9a7; --purple:#7c3aed; --pink:#db2777;
  --text:#dde8f5; --muted:#7a9ab5; --white:#fff;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}

body{
  font-family:'Nunito',sans-serif;
  background:var(--navy);
  color:var(--text);
  min-height:100vh;
  overflow-x:hidden;
  display:flex;
  flex-direction:column;
}

/* Dot grid */
body::after{
  content:'';position:fixed;inset:0;
  background-image:radial-gradient(circle,rgba(255,255,255,0.03) 1px,transparent 1px);
  background-size:26px 26px;pointer-events:none;z-index:0;
}

/* Gold glow top */
body::before{
  content:'';position:fixed;inset:0;
  background:
    radial-gradient(ellipse 70% 40% at 50% 0%,rgba(245,185,66,0.12) 0%,transparent 60%),
    radial-gradient(ellipse 50% 50% at 80% 100%,rgba(0,201,167,0.06) 0%,transparent 60%);
  pointer-events:none;z-index:0;
}

.page{
  position:relative;z-index:1;
  max-width:560px;margin:0 auto;
  padding:40px 20px 60px;
  flex:1;
}

/* ── CONFETTI BURST ── */
.confetti-wrap{
  text-align:center;
  margin-bottom:8px;
  animation:popIn 0.6s cubic-bezier(0.34,1.56,0.64,1) both;
}
.confetti-emoji{font-size:64px;display:block;margin-bottom:4px;}

/* ── HERO ── */
.hero{text-align:center;margin-bottom:32px;animation:fadeDown 0.7s 0.1s ease both;}

.hero-badge{
  display:inline-flex;align-items:center;gap:7px;
  background:rgba(0,200,83,0.12);border:1px solid rgba(0,200,83,0.35);
  color:var(--green2);font-size:11px;font-weight:700;
  letter-spacing:0.1em;text-transform:uppercase;
  padding:6px 16px;border-radius:100px;margin-bottom:18px;
}

.hero h1{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(2.4rem,10vw,3.8rem);
  line-height:1;color:var(--white);
  letter-spacing:0.02em;margin-bottom:10px;
}
.hero h1 .gold{
  background:linear-gradient(90deg,var(--gold),var(--gold2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero-sub{
  font-size:16px;color:var(--muted);line-height:1.6;max-width:420px;margin:0 auto;
}

/* ── DOWNLOAD CARD ── */
.download-card{
  background:linear-gradient(135deg,rgba(0,200,83,0.1),rgba(0,201,167,0.06));
  border:2px solid rgba(0,200,83,0.35);
  border-radius:20px;padding:28px;
  margin-bottom:20px;text-align:center;
  animation:fadeUp 0.6s 0.2s ease both;
}

.pdf-icon{
  width:72px;height:72px;border-radius:16px;
  background:linear-gradient(135deg,var(--green),var(--teal));
  display:flex;align-items:center;justify-content:center;
  font-size:34px;margin:0 auto 16px;
  box-shadow:0 8px 24px rgba(0,200,83,0.3);
}

.download-card h2{
  font-family:'Nunito',sans-serif;
  font-size:20px;font-weight:800;
  color:var(--white);margin-bottom:6px;
}
.download-card p{
  font-size:14px;color:var(--muted);margin-bottom:20px;line-height:1.5;
}

.btn-download{
  display:flex;align-items:center;justify-content:center;gap:10px;
  width:100%;padding:16px 20px;
  background:linear-gradient(135deg,var(--green),var(--green2));
  color:#061826;border:none;border-radius:30px;
  font-family:'Nunito',sans-serif;font-size:17px;font-weight:800;
  cursor:pointer;text-decoration:none;
  box-shadow:0 6px 24px rgba(0,200,83,0.35);
  transition:transform 0.2s,box-shadow 0.2s;
  animation:pulse-green 2s ease-in-out infinite;
}
.btn-download:hover{
  transform:translateY(-2px);
  box-shadow:0 10px 32px rgba(0,200,83,0.5);
  animation:none;
}

.file-meta{
  display:flex;align-items:center;justify-content:center;gap:16px;
  margin-top:14px;font-size:12px;color:var(--muted);
}
.file-meta span{display:flex;align-items:center;gap:4px;}

/* ── WHAT'S INSIDE ── */
.inside-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:18px;padding:22px;
  margin-bottom:20px;
  animation:fadeUp 0.6s 0.3s ease both;
}
.inside-card h3{
  font-family:'Nunito',sans-serif;font-size:16px;font-weight:800;
  color:var(--gold);margin-bottom:14px;
  display:flex;align-items:center;gap:8px;
}

.chapter-list{display:flex;flex-direction:column;gap:8px;}
.chapter{
  display:flex;align-items:center;gap:12px;
  padding:10px 14px;
  background:rgba(255,255,255,0.03);
  border:1px solid var(--border);border-radius:11px;
  font-size:13px;
}
.ch-num{
  width:26px;height:26px;border-radius:50%;flex-shrink:0;
  background:rgba(245,185,66,0.15);border:1px solid rgba(245,185,66,0.3);
  color:var(--gold);font-size:11px;font-weight:800;
  display:flex;align-items:center;justify-content:center;
}
.ch-text strong{display:block;font-size:13px;color:var(--white);}
.ch-text span{font-size:11px;color:var(--muted);}

/* ── NEXT STEPS ── */
.steps-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:18px;padding:22px;
  margin-bottom:20px;
  animation:fadeUp 0.6s 0.4s ease both;
}
.steps-card h3{
  font-family:'Nunito',sans-serif;font-size:16px;font-weight:800;
  color:var(--teal);margin-bottom:14px;
  display:flex;align-items:center;gap:8px;
}
.step{
  display:flex;align-items:flex-start;gap:12px;
  padding:11px 14px;
  background:rgba(255,255,255,0.03);
  border:1px solid var(--border);border-radius:11px;
  margin-bottom:8px;
  font-size:13px;
}
.step:last-child{margin-bottom:0;}
.step-num{
  width:26px;height:26px;border-radius:50%;flex-shrink:0;
  background:rgba(0,201,167,0.15);border:1px solid rgba(0,201,167,0.3);
  color:var(--teal);font-size:11px;font-weight:800;
  display:flex;align-items:center;justify-content:center;
}
.step strong{display:block;font-size:13px;color:var(--white);margin-bottom:2px;}
.step span{font-size:12px;color:var(--muted);}

/* ── SUPPORT ── */
.support-card{
  background:rgba(124,58,237,0.08);border:1px solid rgba(124,58,237,0.25);
  border-radius:14px;padding:18px;text-align:center;
  margin-bottom:20px;
  animation:fadeUp 0.6s 0.5s ease both;
}
.support-card p{font-size:13px;color:var(--muted);line-height:1.6;}
.support-card strong{color:var(--white);}
.support-card a{color:var(--gold);text-decoration:none;font-weight:700;}

/* ── BACK BTN ── */
.back-btn{
  display:block;text-align:center;
  color:var(--muted);font-size:13px;
  text-decoration:none;
  animation:fadeUp 0.6s 0.55s ease both;
  transition:color 0.2s;
}
.back-btn:hover{color:var(--text);}

/* ── FOOTER ── */
footer{
  position:relative;z-index:1;
  text-align:center;padding:16px 20px;
  font-size:12px;color:var(--muted);
  border-top:1px solid var(--border);
}

/* ── ANIMATIONS ── */
@keyframes fadeDown{from{opacity:0;transform:translateY(-16px);}to{opacity:1;transform:translateY(0);}}
@keyframes fadeUp  {from{opacity:0;transform:translateY(20px); }to{opacity:1;transform:translateY(0);}}
@keyframes popIn   {from{opacity:0;transform:scale(0.5);}to{opacity:1;transform:scale(1);}}
@keyframes pulse-green{
  0%,100%{box-shadow:0 6px 24px rgba(0,200,83,0.35);}
  50%{box-shadow:0 6px 36px rgba(0,200,83,0.6);}
}


.navbar{display:flex;align-items:center;justify-content:space-between;padding:10px 20px;background:rgba(6,24,38,0.97);border-bottom:1px solid rgba(245,185,66,0.15);position:sticky;top:0;z-index:999;backdrop-filter:blur(10px);}
.navbar-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.navbar-logo img{width:44px;height:44px;border-radius:50%;object-fit:cover;}
.navbar-brand{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:0.05em;}
.navbar-abn{font-size:10px;color:#7a9ab5;letter-spacing:0.05em;}
.navbar-links{display:flex;align-items:center;gap:16px;font-size:12px;font-weight:700;}
.navbar-links a{color:#7a9ab5;text-decoration:none;transition:color 0.2s;}
.navbar-links a:hover{color:#dde8f5;}

/* ═══ CRYPTO THANK-YOU STYLES ═══ */

:root{
  --navy:#061826;
  --card:#0b2a3d;
  --border:#1a3a52;
  --teal:#00c9a7;
  --teal2:#00e5c2;
  --orange:#f7931a;
  --orange2:#ffb347;
  --gold:#f5b942;
  --green:#00c853;
  --purple:#7c3aed;
  --pink:#db2777;
  --text:#dde8f5;
  --muted:#7a9ab5;
  --white:#fff;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Nunito',sans-serif;background:var(--navy);color:var(--text);min-height:100vh;display:flex;flex-direction:column;}
.top-banner{background:rgba(0,0,0,0.75);border-bottom:1px solid rgba(0,201,167,0.2);text-align:center;padding:10px 16px;font-size:12px;font-weight:700;color:var(--teal);letter-spacing:0.07em;}

/* HERO */
.hero{position:relative;text-align:center;padding:56px 20px 48px;overflow:hidden;background:linear-gradient(180deg,rgba(0,201,167,0.06) 0%,rgba(6,24,38,0) 100%);}
.hero::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:500px;height:500px;background:radial-gradient(circle,rgba(0,201,167,0.08) 0%,transparent 70%);pointer-events:none;}
.success-ring{width:88px;height:88px;border-radius:50%;background:linear-gradient(135deg,rgba(0,201,167,0.2),rgba(247,147,26,0.15));border:2px solid rgba(0,201,167,0.4);display:flex;align-items:center;justify-content:center;font-size:40px;margin:0 auto 24px;position:relative;z-index:1;}
.hero-pill{display:inline-flex;align-items:center;gap:7px;background:rgba(0,201,167,0.12);border:1px solid rgba(0,201,167,0.4);color:var(--teal);font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:6px 18px;border-radius:100px;margin-bottom:18px;}
.hero h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.8rem,10vw,5rem);line-height:1;color:var(--white);margin-bottom:14px;}
.hero h1 span{background:linear-gradient(90deg,var(--teal),var(--orange));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero-sub{font-size:16px;color:rgba(255,255,255,0.75);max-width:420px;margin:0 auto;line-height:1.6;}

/* MAIN BODY */
.page-body{max-width:680px;margin:0 auto;padding:32px 16px 60px;flex:1;width:100%;}

/* DOWNLOAD CARD */
.download-card{background:linear-gradient(135deg,rgba(0,201,167,0.1),rgba(247,147,26,0.07));border:2px solid rgba(0,201,167,0.35);border-radius:22px;padding:32px 28px;text-align:center;margin-bottom:20px;position:relative;overflow:hidden;}
.download-card::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;background:radial-gradient(circle,rgba(0,201,167,0.1),transparent 70%);pointer-events:none;}
.download-icon{font-size:48px;margin-bottom:16px;}
.download-title{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--white);margin-bottom:8px;}
.download-sub{font-size:14px;color:var(--muted);margin-bottom:24px;line-height:1.5;}
.btn-download{display:inline-flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:17px 24px;background:linear-gradient(135deg,var(--teal),var(--orange));color:#061826;font-family:'Nunito',sans-serif;font-size:17px;font-weight:900;border:none;border-radius:14px;cursor:pointer;text-decoration:none;box-shadow:0 6px 28px rgba(0,201,167,0.35);transition:transform 0.2s,box-shadow 0.2s;position:relative;overflow:hidden;}
.btn-download::after{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.18),transparent);transform:skewX(-20deg);animation:shimmer 2.5s infinite;}
.btn-download:hover{transform:translateY(-2px);box-shadow:0 8px 36px rgba(0,201,167,0.5);}
.btn-download-icon{font-size:22px;}
.secure-note{margin-top:12px;font-size:12px;color:var(--muted);display:flex;align-items:center;justify-content:center;gap:6px;}

/* WHAT'S INSIDE */
.section-label{text-align:center;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:16px;display:flex;align-items:center;gap:12px;}
.section-label::before,.section-label::after{content:'';flex:1;height:1px;background:var(--border);}
.chapters{display:flex;flex-direction:column;gap:8px;margin-bottom:20px;}
.chapter{display:flex;align-items:center;gap:12px;background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:11px;padding:11px 14px;}
.ch-num{font-family:'Bebas Neue',sans-serif;font-size:18px;color:var(--teal);min-width:28px;}
.ch-text{font-size:13px;color:var(--text);font-weight:600;}

/* SUPPORT CARD */
.support-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:22px;margin-bottom:20px;text-align:center;}
.support-title{font-size:16px;font-weight:800;color:var(--white);margin-bottom:8px;}
.support-text{font-size:13px;color:var(--muted);margin-bottom:14px;line-height:1.6;}
.email-link{display:inline-flex;align-items:center;gap:8px;background:rgba(0,201,167,0.08);border:1px solid rgba(0,201,167,0.25);color:var(--teal);font-weight:700;font-size:14px;padding:10px 20px;border-radius:30px;text-decoration:none;transition:background 0.2s;}
.email-link:hover{background:rgba(0,201,167,0.15);}

/* BACK LINK */
.back-link{display:flex;align-items:center;justify-content:center;gap:8px;font-size:14px;color:var(--muted);text-decoration:none;margin-bottom:20px;}
.back-link:hover{color:var(--teal);}

/* SCAM WARNING */
.scam-box{background:rgba(247,147,26,0.07);border:1px solid rgba(247,147,26,0.2);border-radius:12px;padding:14px 16px;font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:20px;}
.scam-box strong{color:var(--orange);}

footer{background:rgba(0,0,0,0.4);border-top:1px solid var(--border);padding:20px 24px;text-align:center;font-size:12px;color:var(--muted);line-height:1.8;}
footer a{color:var(--muted);text-decoration:none;}
footer a:hover{color:var(--teal);}

@keyframes shimmer{0%{left:-100%;}100%{left:200%;}}


.navbar{display:flex;align-items:center;justify-content:space-between;padding:10px 20px;background:rgba(6,24,38,0.97);border-bottom:1px solid rgba(245,185,66,0.15);position:sticky;top:0;z-index:999;backdrop-filter:blur(10px);}
.navbar-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.navbar-logo img{width:44px;height:44px;border-radius:50%;object-fit:cover;}
.navbar-brand{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:0.05em;}
.navbar-abn{font-size:10px;color:#7a9ab5;letter-spacing:0.05em;}
.navbar-links{display:flex;align-items:center;gap:16px;font-size:12px;font-weight:700;}
.navbar-links a{color:#7a9ab5;text-decoration:none;transition:color 0.2s;}
.navbar-links a:hover{color:#dde8f5;}

/* ═══ CRYPTO PAGE STYLES ═══ */
 :root{ --navy:#061826; --card:#0b2a3d; --card2:#0f2a3d; --border:#1a3a52; --gold:#f5b942; --gold2:#ffd47a; --green:#00c853; --green2:#00e676; --teal:#00c9a7; --teal2:#00e5c2; --orange:#f7931a; --orange2:#ffb347; --rose:#ff6b8a; --purple:#7c3aed; --pink:#db2777; --text:#dde8f5; --muted:#7a9ab5; --white:#fff; } *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;} html{scroll-behavior:smooth;} body{font-family:'Nunito',sans-serif;background:var(--navy);color:var(--text);min-height:100vh;overflow-x:hidden;} .top-banner{background:rgba(0,0,0,0.75);border-bottom:1px solid rgba(0,201,167,0.2);text-align:center;padding:10px 16px;font-size:12px;font-weight:700;color:var(--teal);letter-spacing:0.07em;position:relative;z-index:10;} .hero{position:relative;text-align:center;padding:64px 20px 110px;overflow:hidden;min-height:560px;display:flex;align-items:center;justify-content:center;} .hero-bg{ position:absolute;inset:0; background: linear-gradient(180deg,rgba(6,24,38,0.40) 0%,rgba(6,24,38,0.55) 45%,rgba(6,24,38,0.96) 100%), url('https://images.pexels.com/photos/8370752/pexels-photo-8370752.jpeg?auto=compress&cs=tinysrgb&w=1400') center 55%/cover no-repeat; z-index:0; } .hero-inner{position:relative;z-index:2;width:100%;max-width:640px;margin:0 auto;} .hero-pill{display:inline-flex;align-items:center;gap:7px;background:rgba(0,201,167,0.12);border:1px solid rgba(0,201,167,0.4);color:var(--teal);font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:6px 18px;border-radius:100px;margin-bottom:24px;} .hero h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.8rem,14vw,8rem);line-height:0.9;color:var(--white);margin-bottom:18px;letter-spacing:0.01em;text-shadow:0 4px 32px rgba(0,0,0,0.9);} .hero h1 .teal{background:linear-gradient(90deg,var(--teal),var(--teal2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;} .hero h1 .orange{background:linear-gradient(90deg,var(--orange),var(--orange2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;} .hero-sub{font-size:17px;color:rgba(255,255,255,0.82);max-width:440px;margin:0 auto 28px;line-height:1.65;text-shadow:0 2px 10px rgba(0,0,0,0.8);} .ticker{background:rgba(11,42,61,0.85);border:1px solid rgba(0,201,167,0.25);border-radius:10px;padding:12px 20px;margin:0 auto 28px;max-width:540px;font-size:14px;color:var(--teal);font-weight:600;display:flex;align-items:center;gap:10px;backdrop-filter:blur(8px);} .stats{display:flex;justify-content:center;max-width:520px;margin:0 auto 28px;background:rgba(11,42,61,0.8);border:1px solid var(--border);border-radius:14px;overflow:hidden;backdrop-filter:blur(8px);} .stat{flex:1;padding:14px 8px;text-align:center;border-right:1px solid var(--border);} .stat:last-child{border-right:none;} .stat-icon{font-size:20px;margin-bottom:3px;} .stat-val{font-family:'Bebas Neue',sans-serif;font-size:26px;line-height:1;background:linear-gradient(90deg,var(--teal),var(--teal2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;} .stat-label{font-size:10px;color:var(--muted);margin-top:2px;} .scroll-arrow{display:flex;flex-direction:column;align-items:center;cursor:pointer;animation:bounceArrow 2s ease-in-out infinite;} .scroll-arrow span{font-size:11px;color:rgba(255,255,255,0.45);font-weight:600;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:8px;} .arrow-ring{width:38px;height:38px;border-radius:50%;border:2px solid rgba(0,201,167,0.5);background:rgba(0,201,167,0.1);display:flex;align-items:center;justify-content:center;color:var(--teal);font-size:16px;} .page-body{max-width:960px;margin:0 auto;padding:32px 16px 60px;} .section-label{text-align:center;font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:20px;display:flex;align-items:center;gap:12px;} .section-label::before,.section-label::after{content:'';flex:1;height:1px;background:var(--border);} .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;} @media(max-width:640px){.grid-2{grid-template-columns:1fr;}} .pcard{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:22px;transition:border-color 0.2s,transform 0.2s;} .pcard:hover{border-color:rgba(0,201,167,0.28);transform:translateY(-1px);} .pcard-full{grid-column:1/-1;} .pcard-header{display:flex;align-items:center;gap:14px;margin-bottom:16px;} .pcard-icon{width:46px;height:46px;border-radius:13px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;} .ic-teal{background:rgba(0,201,167,0.13);} .ic-orange{background:rgba(247,147,26,0.15);} .ic-gold{background:rgba(245,185,66,0.15);} .ic-purple{background:rgba(124,58,237,0.15);} .pcard-title{font-size:18px;font-weight:800;color:var(--white);line-height:1.2;} .pcard-sub{font-size:12px;color:var(--muted);margin-top:2px;} .exchange-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px;} .ex-btn{display:flex;flex-direction:column;align-items:center;padding:12px 8px;background:rgba(255,255,255,0.03);border:1.5px solid var(--border);border-radius:11px;cursor:default;text-align:center;} .ex-icon{font-size:22px;margin-bottom:4px;} .ex-name{font-size:10px;color:var(--muted);font-weight:700;} .feature-list{display:flex;flex-direction:column;gap:9px;margin-bottom:16px;} .fi{display:flex;align-items:center;gap:9px;font-size:14px;} .fd{width:20px;height:20px;border-radius:50%;background:rgba(0,201,167,0.2);border:1px solid rgba(0,201,167,0.4);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--teal);flex-shrink:0;} .price-box{background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:14px;padding:20px;text-align:center;min-width:155px;} .price-label{font-size:12px;color:var(--muted);margin-bottom:4px;} .price-val{font-family:'Bebas Neue',sans-serif;font-size:52px;line-height:1;background:linear-gradient(135deg,var(--teal),var(--teal2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;} .price-note{font-size:12px;color:var(--muted);margin-top:4px;} .btn{width:100%;padding:15px 20px;border:none;border-radius:30px;font-family:'Nunito',sans-serif;font-size:16px;font-weight:800;cursor:pointer;letter-spacing:0.01em;transition:transform 0.2s,box-shadow 0.2s,opacity 0.15s;} .btn:hover{transform:translateY(-2px);opacity:0.93;} .btn-teal{background:linear-gradient(90deg,var(--teal),var(--teal2));color:#061826;box-shadow:0 4px 22px rgba(0,201,167,0.3);} .btn-teal:hover{box-shadow:0 6px 28px rgba(0,201,167,0.5);} .btn-crypto{background:linear-gradient(135deg,var(--teal),var(--orange));color:#061826;box-shadow:0 4px 22px rgba(0,201,167,0.3);position:relative;overflow:hidden;border-radius:12px;} .btn-crypto::after{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent);transform:skewX(-20deg);animation:shimmer 2.8s infinite;} .btn-crypto:hover{box-shadow:0 6px 30px rgba(0,201,167,0.45);} .warn-box{background:rgba(247,147,26,0.08);border:1px solid rgba(247,147,26,0.25);border-radius:12px;padding:14px 16px;font-size:13px;color:var(--muted);margin-bottom:14px;line-height:1.6;} .warn-box strong{color:var(--orange);} .trust-bar{display:flex;justify-content:center;gap:22px;flex-wrap:wrap;padding:20px;border-top:1px solid var(--border);margin-top:32px;} .ti{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--muted);} .tdot{width:6px;height:6px;border-radius:50%;background:var(--teal);} .premium-inner{display:grid;grid-template-columns:1fr auto;gap:20px;align-items:start;} @media(max-width:500px){.premium-inner{grid-template-columns:1fr;}} footer{background:rgba(0,0,0,0.4);border-top:1px solid var(--border);padding:20px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;font-size:12px;color:var(--muted);} .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.93);z-index:1000;overflow-y:auto;padding:20px;} .modal-overlay.open{display:flex;align-items:flex-start;justify-content:center;animation:fadeIn 0.2s ease;} .modal-box{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:28px;width:100%;max-width:520px;margin:40px auto;position:relative;animation:slideUp 0.35s cubic-bezier(0.34,1.56,0.64,1);} .modal-close{position:absolute;top:16px;right:16px;background:none;border:none;color:var(--teal);font-size:24px;cursor:pointer;line-height:1;} .modal-title{font-size:26px;font-weight:800;color:var(--teal);text-align:center;margin-bottom:6px;} .modal-sub{text-align:center;color:var(--muted);font-size:14px;margin-bottom:24px;} .modal-features{list-style:none;margin-bottom:24px;} .modal-features li{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:15px;} .modal-features li:last-child{border-bottom:none;} .modal-features li::before{content:'✅';font-size:16px;flex-shrink:0;} .modal-secure{text-align:center;margin-top:12px;font-size:12px;color:var(--muted);} .chat-fab{position:fixed;bottom:24px;right:20px;width:54px;height:54px;border-radius:50%;background:linear-gradient(135deg,var(--purple),var(--pink));box-shadow:0 6px 24px rgba(124,58,237,0.5);display:flex;align-items:center;justify-content:center;font-size:24px;cursor:pointer;z-index:900;transition:transform 0.2s;} .chat-fab:hover{transform:scale(1.08);} .chat-window{position:fixed;bottom:90px;right:20px;width:310px;background:#0b2a3d;border:1px solid var(--border);border-radius:18px;box-shadow:0 16px 48px rgba(0,0,0,0.6);z-index:900;display:none;flex-direction:column;overflow:hidden;} .chat-window.open{display:flex;} .chat-head{background:linear-gradient(135deg,var(--teal),var(--orange));padding:14px 16px;display:flex;align-items:center;justify-content:space-between;} .chat-head-left{display:flex;align-items:center;gap:10px;} .chat-avatar{width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:18px;} .chat-agent-name{font-weight:700;font-size:14px;color:white;} .chat-online{font-size:11px;color:rgba(255,255,255,0.75);display:flex;align-items:center;gap:4px;} .online-dot{width:6px;height:6px;border-radius:50%;background:#4ade80;} .chat-close-btn{color:white;font-size:20px;cursor:pointer;background:none;border:none;} .chat-body{padding:14px;height:240px;overflow-y:auto;display:flex;flex-direction:column;gap:10px;} .msg{display:flex;gap:8px;align-items:flex-start;} .msg-bot .bubble{background:rgba(255,255,255,0.07);border-radius:12px 12px 12px 3px;padding:10px 12px;font-size:13px;color:var(--text);max-width:85%;} .msg-user{justify-content:flex-end;} .msg-user .bubble{background:linear-gradient(135deg,var(--teal),var(--orange));border-radius:12px 12px 3px 12px;padding:10px 12px;font-size:13px;color:white;max-width:85%;} .bot-av{width:26px;height:26px;border-radius:50%;background:rgba(0,201,167,0.3);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;} .chat-input-row{display:flex;gap:8px;padding:12px 14px;border-top:1px solid var(--border);} .chat-input{flex:1;padding:9px 12px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:9px;color:var(--white);font-family:'Nunito',sans-serif;font-size:13px;outline:none;} .chat-input::placeholder{color:var(--muted);} .chat-send{width:34px;height:34px;border-radius:9px;background:linear-gradient(135deg,var(--teal),var(--orange));border:none;color:white;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;} @keyframes fadeIn{from{opacity:0;}to{opacity:1;}} @keyframes slideUp{from{opacity:0;transform:translateY(40px) scale(0.97);}to{opacity:1;transform:translateY(0) scale(1);}} @keyframes shimmer{0%{left:-100%;}100%{left:200%;}} @keyframes bounceArrow{0%,100%{transform:translateY(0);opacity:1;}50%{transform:translateY(8px);opacity:0.6;}} 

.navbar{display:flex;align-items:center;justify-content:space-between;padding:10px 20px;background:rgba(6,24,38,0.97);border-bottom:1px solid rgba(245,185,66,0.15);position:sticky;top:0;z-index:999;backdrop-filter:blur(10px);}
.navbar-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.navbar-logo img{width:44px;height:44px;border-radius:50%;object-fit:cover;}
.navbar-brand{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:0.05em;}
.navbar-abn{font-size:10px;color:#7a9ab5;letter-spacing:0.05em;}
.navbar-links{display:flex;align-items:center;gap:16px;font-size:12px;font-weight:700;}
.navbar-links a{color:#7a9ab5;text-decoration:none;transition:color 0.2s;}
.navbar-links a:hover{color:#dde8f5;}

/* ═══ STORY MODAL ═══ */
#story-modal{position:fixed;inset:0;background:rgba(0,0,0,0.9);z-index:9999;display:none;align-items:center;justify-content:center;padding:20px;}
#story-modal.open{display:flex;}
.story-box{background:#0b2a3d;border:1px solid rgba(245,185,66,0.2);border-radius:20px;padding:28px;max-width:560px;width:100%;position:relative;max-height:85vh;overflow-y:auto;}
.story-close{position:absolute;top:16px;right:16px;background:none;border:none;color:var(--muted);font-size:24px;cursor:pointer;}
</style>
</head>
<body>

<!-- STORY MODAL -->
